---
import { Icon } from "astro-icon/components";
import { parseHTML } from "linkedom";

const html = await Astro.slots.render("default");
const { document } = parseHTML(html);
const children = Array.from(document.children);
const numSlides = children.length;

children.forEach((child, index) => {
  child.setAttribute("data-index", String(index));
});

const slidesHtml = children.map((child) => child.outerHTML).join("");
---

<div class="carousel-wrapper full-bleed my-8">
  <div class="carousel-viewport w-full overflow-hidden">
    <div
      class="carousel flex items-center gap-8 overflow-x-auto snap-x snap-mandatory scroll-smooth [scrollbar-width:none]"
    >
      <div class="shrink-0 w-[50vw]"></div>
      <Fragment set:html={slidesHtml} />
      <div class="shrink-0 w-[50vw]"></div>
    </div>
  </div>

  <div class="not-prose mt-4 flex items-center justify-center">
    <button
      class="navigation-button prev-button h-[3rem] w-[3rem] cursor-pointer content-center disabled:cursor-not-allowed disabled:opacity-50 active:[&>svg]:scale-none!"
      type="button"
      ><Icon
        class="mx-auto h-[2rem] w-[2rem] dark:text-zinc-200"
        name="ri:arrow-drop-left-line"
      /></button
    >
    <div class="flex gap-2 mx-4">
      {
        Array.from({ length: numSlides }).map(() => (
          <button
            class="page-button flex items-center justify-center cursor-pointer content-center active:[&>div]:scale-none!"
            type="button"
          >
            <div class="h-[0.5rem] w-[0.5rem] rounded-full bg-black/40 transition dark:bg-zinc-200/40" />
          </button>
        ))
      }
    </div>
    <button
      class="navigation-button next-button h-[3rem] w-[3rem] cursor-pointer content-center disabled:cursor-not-allowed disabled:opacity-50 active:[&>svg]:scale-none!"
      type="button"
      ><Icon
        class="mx-auto h-[2rem] w-[2rem] transition dark:text-zinc-200"
        name="ri:arrow-drop-right-line"
      /></button
    >
  </div>
</div>

<script>
  const carousels = document.querySelectorAll(
    "div.carousel-wrapper",
  ) as NodeListOf<HTMLDivElement>;

  carousels.forEach((wrapper) => {
    const scrollContainer = wrapper.querySelector(
      "div.carousel",
    ) as HTMLDivElement;
    const slideViewports = wrapper.querySelectorAll(
      "div.slide-viewport",
    ) as NodeListOf<HTMLDivElement>;
    const prevButton = wrapper.querySelector(
      "button.prev-button",
    ) as HTMLButtonElement;
    const nextButton = wrapper.querySelector(
      "button.next-button",
    ) as HTMLButtonElement;
    const paginationButtons = wrapper.querySelectorAll(
      "button.page-button",
    ) as NodeListOf<HTMLButtonElement>;

    if (
      !scrollContainer ||
      !prevButton ||
      !nextButton ||
      slideViewports.length === 0
    ) {
      return;
    }

    let currentIndex = 0;
    // Flag to suppress IntersectionObserver updates during programmatic scrolls,
    // which would otherwise cause the double-step bug.
    let isProgrammaticScroll = false;
    let scrollEndTimer: ReturnType<typeof setTimeout> | null = null;

    function updateButtonStates() {
      prevButton.disabled = currentIndex === 0;
      nextButton.disabled = currentIndex === slideViewports.length - 1;
      paginationButtons.forEach((item, index) => {
        item.classList.toggle("active", index === currentIndex);
      });
      slideViewports.forEach((item, index) => {
        item.classList.toggle("active", index === currentIndex);
      });
    }

    function scrollToSlide(index: number, smooth = true) {
      const targetSlide = slideViewports[index];
      const containerWidth = scrollContainer.offsetWidth;
      const slideWidth = targetSlide.offsetWidth;
      const scrollLeft = targetSlide.offsetLeft - containerWidth / 2 + slideWidth / 2;

      if (smooth) {
        isProgrammaticScroll = true;
        if (scrollEndTimer) clearTimeout(scrollEndTimer);
        scrollContainer.scrollTo({ left: scrollLeft, behavior: "smooth" });
        // After smooth scroll finishes (~400ms), re-enable the observer.
        scrollEndTimer = setTimeout(() => {
          isProgrammaticScroll = false;
        }, 600);
      } else {
        // Instant scroll — does NOT affect page scroll position.
        scrollContainer.scrollLeft = scrollLeft;
      }
    }

    function goToSlide(index: number) {
      if (index < 0 || index >= slideViewports.length) {
        return;
      }
      currentIndex = index;
      updateButtonStates();
      scrollToSlide(index);
    }

    prevButton.addEventListener("click", () => {
      goToSlide(currentIndex - 1);
    });

    nextButton.addEventListener("click", () => {
      goToSlide(currentIndex + 1);
    });

    paginationButtons.forEach((item, index) => {
      item.addEventListener("click", () => {
        goToSlide(index);
      });
    });

    // Initial centering — instant, so the page doesn't scroll on load.
    scrollToSlide(0, false);
    updateButtonStates();

    // Use scroll event to sync highlighted slide with the one closest to center.
    // This correctly handles trackpad/mouse wheel free scrolling.
    let scrollDebounce: ReturnType<typeof setTimeout> | null = null;

    function updateActiveFromScroll() {
      if (isProgrammaticScroll) return;
      const containerCenter = scrollContainer.scrollLeft + scrollContainer.offsetWidth / 2;
      let closestIndex = 0;
      let closestDistance = Infinity;
      slideViewports.forEach((slide, index) => {
        const slideCenter = slide.offsetLeft + slide.offsetWidth / 2;
        const distance = Math.abs(slideCenter - containerCenter);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });
      if (closestIndex !== currentIndex) {
        currentIndex = closestIndex;
        updateButtonStates();
      }
    }

    scrollContainer.addEventListener("scroll", () => {
      // Update highlight in real time while scrolling.
      updateActiveFromScroll();
      // Snap to the closest slide once scrolling settles.
      if (scrollDebounce) clearTimeout(scrollDebounce);
      scrollDebounce = setTimeout(() => {
        if (!isProgrammaticScroll) {
          scrollToSlide(currentIndex);
        }
      }, 150);
    });
  });
</script>

<style>
  @reference "../styles/global.css";

  @media (hover: none) and (pointer: coarse) {
    .navigation-button {
      display: none;
    }
  }

  .page-button.active > div {
    @apply scale-[1.5] bg-black dark:bg-white;
  }

  .page-button:active > div {
    @apply scale-100;
  }

  @media (hover: hover) {
    .page-button:hover > div,
    .navigation-button:hover:not(:disabled) > svg {
      @apply scale-[1.3];
    }
  }
</style>
