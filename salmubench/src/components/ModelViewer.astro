---
interface Props {
  src: string;
  alt?: string;
}
const { src, alt } = Astro.props;

// Prepend base path for public assets referenced by absolute path
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const resolvedSrc = src.startsWith("/") ? `${base}${src}` : src;
---

<model-viewer
  class="my-6 overflow-hidden rounded-lg bg-zinc-200 dark:bg-zinc-800"
  alt={alt}
  src={resolvedSrc}
  camera-controls></model-viewer>
<script>
  import "@google/model-viewer";
</script>
